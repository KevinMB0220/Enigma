#!/bin/bash
# Hook: Auto-add real developer as Co-authored-by
# The repo uses snowrailsnowrail@gmail.com as the commit author (local config).
# This hook reads the developer's GLOBAL git identity and appends it as co-author.
#
# IMPORTANT: Co-authored-by MUST be the last line(s) of the commit message
# for GitHub to properly parse and link the co-author avatars.

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Skip for merges, amends, squashes, etc.
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ]; then
  exit 0
fi

# Get the real developer identity from global git config
REAL_NAME=$(git config --global user.name)
REAL_EMAIL=$(git config --global user.email)

# Skip if no global config or if it's the same as the repo author
REPO_EMAIL=$(git config user.email)
if [ -z "$REAL_EMAIL" ] || [ "$REAL_EMAIL" = "$REPO_EMAIL" ]; then
  exit 0
fi

# Skip if Co-authored-by is already present for this user
if grep -q "Co-authored-by:.*<${REAL_EMAIL}>" "$COMMIT_MSG_FILE" 2>/dev/null; then
  exit 0
fi

# Remove trailing blank lines from the commit message
sed -i '' -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE"

# Append Co-authored-by as the LAST line (required by GitHub for proper linking)
echo "" >> "$COMMIT_MSG_FILE"
echo "Co-authored-by: ${REAL_NAME} <${REAL_EMAIL}>" >> "$COMMIT_MSG_FILE"
