// Prisma Schema for Enigma
// Trust Score Platform for Autonomous Agents on Avalanche

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// CORE ENTITIES
// ============================================

/// Autonomous Agent Type
enum AgentType {
  TRADING
  LENDING
  GOVERNANCE
  ORACLE
  CUSTOM
}

/// Agent Status
enum AgentStatus {
  PENDING
  VERIFIED
  FLAGGED
  SUSPENDED
}

/// Proxy Pattern Type
enum ProxyType {
  NONE
  EIP1967
  BEACON
  TRANSPARENT
  CUSTOM
}

/// Autonomous Agent registered on the platform
model Agent {
  address                 String       @id // Contract address (0x...)
  name                    String
  type                    AgentType
  description             String?
  owner_address           String       // Wallet that registered
  billing_address         String?      // ERC-804 billing address

  // Status and verification
  status                  AgentStatus  @default(PENDING)
  trust_score             Int          @default(0) // 0-100

  // Proxy detection
  is_proxy                Boolean      @default(false)
  proxy_type              ProxyType    @default(NONE)
  implementation_address  String?

  // Timestamps
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt

  // Relations (keeping existing relations for compatibility)
  trustScores     TrustScore[]
  ratings         Rating[]
  scannerResults  ScannerResult[]
  watchlistItems  WatchlistItem[]

  @@index([type])
  @@index([status])
  @@index([trust_score(sort: Desc)])
  @@index([owner_address])
  @@map("agents")
}

/// Trust Score calculation snapshot
model TrustScore {
  id             String   @id @default(uuid())
  agentId        String   @map("agent_id")

  // Score components (0.0 - 1.0)
  overallScore   Float    @map("overall_score")
  volumeScore    Float    @map("volume_score")
  proxyScore     Float    @map("proxy_score")
  uptimeScore    Float    @map("uptime_score")
  ozMatchScore   Float    @map("oz_match_score")
  communityScore Float    @map("community_score")

  // Calculation metadata
  calculatedAt   DateTime @default(now()) @map("calculated_at")
  snapshotData   Json?    @map("snapshot_data")

  // Relations
  agent          Agent    @relation(fields: [agentId], references: [address], onDelete: Cascade)

  @@index([agentId])
  @@index([calculatedAt])
  @@index([overallScore])
  @@map("trust_scores")
}

/// User rating and review for an agent
model Rating {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  userAddress String   @map("user_address")

  // Rating (1-5)
  rating      Int
  review      String?

  // Blockchain reference
  txHash      String?  @map("tx_hash")

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  agent       Agent    @relation(fields: [agentId], references: [address], onDelete: Cascade)

  @@unique([agentId, userAddress])
  @@index([userAddress])
  @@index([createdAt])
  @@map("ratings")
}

// ============================================
// USER MANAGEMENT
// ============================================

/// Platform user (wallet-based)
model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique @map("wallet_address")
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")

  // Permissions
  isAdmin       Boolean   @default(false) @map("is_admin")

  // Timestamps
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  watchlists    Watchlist[]
  apiKeys       ApiKey[]

  @@index([walletAddress])
  @@map("users")
}

/// User's watchlist for tracking agents
model Watchlist {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  name      String

  // Timestamps
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  // Relations
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]

  @@index([userId])
  @@map("watchlists")
}

/// Agent in a watchlist
model WatchlistItem {
  id          String    @id @default(uuid())
  watchlistId String    @map("watchlist_id")
  agentId     String    @map("agent_id")
  addedAt     DateTime  @default(now()) @map("added_at")

  // Relations
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  agent       Agent     @relation(fields: [agentId], references: [address], onDelete: Cascade)

  @@unique([watchlistId, agentId])
  @@map("watchlist_items")
}

// ============================================
// SCANNER & ANALYSIS
// ============================================

/// Security scan result for an agent
model ScannerResult {
  id          String    @id @default(uuid())
  agentId     String    @map("agent_id")

  // Scan metadata
  scanType    String    @map("scan_type") // bytecode, transaction, pattern, full
  status      String    @default("pending") // pending, running, completed, failed

  // Results
  findings    Json?

  // Timestamps
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  agent       Agent     @relation(fields: [agentId], references: [address], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([startedAt])
  @@map("scanner_results")
}

// ============================================
// API & INTEGRATION
// ============================================

/// API Key for external integrations
model ApiKey {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  name        String
  keyHash     String    @unique @map("key_hash")

  // Permissions
  permissions String[]

  // Rate limiting
  rateLimit   Int       @default(1000) @map("rate_limit")

  // Status
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ============================================
// ANALYTICS & METRICS
// ============================================

/// Daily metrics snapshot
model DailyMetric {
  id              String   @id @default(uuid())
  date            DateTime @db.Date

  // Platform metrics
  totalAgents     Int      @map("total_agents")
  newAgents       Int      @map("new_agents")
  verifiedAgents  Int      @map("verified_agents")
  totalScans      Int      @map("total_scans")
  totalRatings    Int      @map("total_ratings")
  activeUsers     Int      @map("active_users")

  // Trust score distribution
  avgTrustScore   Float    @map("avg_trust_score")

  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@index([date])
  @@map("daily_metrics")
}
